{{ define "string_validation" }}
    {
    {{- $hasRequired := false }}
    {{- $hasOptional := false }}
    {{- range .Directives }}
        {{- if eq .Type "required" }}{{ $hasRequired = true }}{{ end }}
        {{- if eq .Type "optional" }}{{ $hasOptional = true }}{{ end }}
    {{- end }}

    builder := validator.New[string]("{{ .Name }}")
    {{- range .Directives }}
        {{- if eq .Type "required" }}
            builder.AddRule(validator.Required[string]())
        {{- else if eq .Type "min" }}
            builder.AddRule(validator.MinLen({{ index .Params 0 }}))
        {{- else if eq .Type "max" }}
            builder.AddRule(validator.MaxLen({{ index .Params 0 }}))
        {{- else if eq .Type "not-zero" }}
            builder.AddRule(validator.NotEmpty())
        {{- else if eq .Type "eq" }}
            builder.AddRule(validator.Eq({{ index .Params 0 | printf "%q" }}))
        {{- else if eq .Type "neq" }}
            builder.AddRule(validator.Neq({{ index .Params 0 | printf "%q" }}))
        {{- else if eq .Type "pattern" }}
            {{- $pattern := index .Params 0 }}
            {{- if eq $pattern "email" }}
                builder.AddRule(validator.Email())
            {{- else if eq $pattern "phone" }}
                builder.AddRule(validator.Phone())
            {{- else if eq $pattern "uuid" }}
                builder.AddRule(validator.UUID())
            {{- else }}
                builder.AddRule(validator.MatchRegexp({{ $pattern | printf "%q" }}))
            {{- end }}
        {{- end }}
    {{- end }}

    {{- if and (not $hasRequired) $hasOptional }}
        if v.{{ .Name }} != "" {
        if err := builder.Validate(v.{{ .Name }}); err != nil {
        errs = append(errs, err)
        }
        }
    {{- else }}
        if err := builder.Validate(v.{{ .Name }}); err != nil {
        errs = append(errs, err)
        }
    {{- end }}
    }
{{ end }}
