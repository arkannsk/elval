{{ define "openapi/field/annotations" }}
    {{- $field := . }}
    {{- $module := $.Module }}
    {{- $pkgPath := $.PkgPath }}

    {{- if $.Field }}
        {{- $field = $.Field }}
        {{- $module = $.Module }}
        {{- $pkgPath = $.PkgPath }}
    {{- end }}

    {{- range $oa := $field.OaAnnotations }}
        {{- if eq $oa.Type "title" }}
            prop.Title = {{ oaString $oa.Value }}
        {{- else if eq $oa.Type "description" }}
            prop.Description = {{ oaString $oa.Value }}
        {{- else if eq $oa.Type "example" }}
            prop.Example = {{ printf "%q" (trimQuotes $oa.Value) }}
        {{- else if eq $oa.Type "format" }}
            {{- if eq $oa.Value "email" }}
                prop.Format = "email"
            {{- else if eq $oa.Value "phone" }}
                prop.Format = "phone"
            {{- else if eq $oa.Value "uuid" }}
                prop.Format = "uuid"
            {{- else }}
                prop.Format = {{ oaString $oa.Value }}
            {{- end }}

        {{- else if eq $oa.Type "oneOf" }}
            {{- $clean := trimQuotes $oa.Value }}
            prop.OneOf = []oa.Schema{
            {{- range $t := split $clean "," }}
                {{- $typeName := trimQuotes (trim $t) }}
                {{- $ref := buildGlobalRef $typeName $.PkgPath $.Module }}
                {Ref: "#/components/schemas/{{ $ref }}"},
            {{- end }}
            }

        {{- else if eq $oa.Type "oneOf-ref" }}
            {{- $clean := trimQuotes $oa.Value }}
            prop.OneOf = []oa.Schema{
            {{- range $r := split $clean "," }}
                {{- $ref := trimQuotes (trim $r) }}
                {Ref: {{ printf "%q" $ref }}},
            {{- end }}
            }

        {{- else if eq $oa.Type "anyOf" }}
            {{- $clean := trimQuotes $oa.Value }}
            prop.AnyOf = []oa.Schema{
            {{- range $t := split $clean "," }}
                {{- $typeName := trimQuotes (trim $t) }}
                {{- $ref := buildGlobalRef $typeName $.PkgPath $.Module }}
                {Ref: "#/components/schemas/{{ $ref }}"},
            {{- end }}
            }

        {{- else if eq $oa.Type "anyOf-ref" }}
            {{- $clean := trimQuotes $oa.Value }}
            prop.AnyOf = []oa.Schema{
            {{- range $r := split $clean "," }}
                {{- $ref := trimQuotes (trim $r) }}
                {Ref: {{ printf "%q" $ref }}},
            {{- end }}
            }
        {{- end }}
    {{- end }}
{{ end }}
