{{ define "openapi/schema" }}
    func (v *{{ .Name }}) OaSchema() *oa.Schema {
    schema := &oa.Schema{
    Type:       "object",
    Properties: make(map[string]oa.Schema, {{ len .Fields }}),
    Required:   make([]string, 0, {{ len .Fields }}),
    Ref:        v.GlobalRef(),
    }

    {{- if .Description }}
        schema.Description = {{ oaString .Description }}
    {{- end }}

    {{- range $field := .Fields }}
        {
        prop := oa.Schema{}

        {{- /* ПРИОРИТЕТ 1: Явное переопределение типа на примитив (@oa:rewrite.type) */}}
        {{- if $field.OaRewriteType }}
            {{- if eq $field.OaRewriteType "string" }}
                prop.Type = "string"
            {{- else if eq $field.OaRewriteType "integer" }}
                prop.Type = "integer"
            {{- else if eq $field.OaRewriteType "number" }}
                prop.Type = "number"
            {{- else if eq $field.OaRewriteType "boolean" }}
                prop.Type = "boolean"
            {{- else if eq $field.OaRewriteType "array" }}
                prop.Type = "array"
                prop.Items = &oa.Schema{}
            {{- end }}

            {{- /* ПРИОРИТЕТ 2: Структуры (не слайсы) */}}
        {{- else if and $field.Type.IsStruct (not $field.Type.IsSlice) }}
            {{- if $field.OaRewriteRef }}
                prop.Ref = "#/components/schemas/{{ $field.OaRewriteRef }}"
            {{- else }}
                prop.Ref = "#/components/schemas/{{ globalRefFor $field.Type.Name $field.Type.PackagePath $field.Type.Module $.PackagePath $.Module }}"
            {{- end }}

            {{- /* ПРИОРИТЕТ 3: Слайсы и массивы — делегируем в специализированный шаблон slice */}}
        {{- else if $field.Type.IsSlice }}
            {{- $ctx := dict "Field" $field "PkgPath" $.PackagePath "Module" $.Module }}
            {{ template "openapi/field/slice" $ctx }}

            {{- /* ПРИОРИТЕТ 4: Всё остальное (примитивы, указатели на примитивы, map и т.д.) */}}
        {{- else }}
            {{- $ctx := dict "Field" $field "Pkg" $.Package "PkgPath" $.PackagePath "Module" $.Module }}
            {{ template "openapi/field/type" $ctx }}
        {{- end }}

        {{- /* Валидаторы, аннотации, описание */}}
        {{ template "openapi/field/validators" $field }}
        {{- $ctx := dict "Field" $field "Pkg" $.Package "PkgPath" $.PackagePath "Module" $.Module }}
        {{ template "openapi/field/annotations" $ctx }}
        {{ template "openapi/field/description" $field }}

        schema.Properties[{{ $field.Name | toLower | printf "%q" }}] = prop
        }
    {{- end }}

    {{- /* Discriminator вызывается ЗДЕСЬ, вне цикла, с контекстом структуры (.) */}}
    {{ template "openapi/discriminator" . }}

    return schema
    }

    func (v *{{ .Name }}) GlobalRef() string {
    {{- $ref := .Name }}
    {{- if .PackagePath }}
        {{- $ref = print .PackagePath "." .Name }}
        {{- if .Module }}
            {{- $ref = print .Module "/" $ref }}
        {{- end }}
    {{- else if .Package }}
        {{- $ref = print .Package "." .Name }}
    {{- end }}
    return {{ printf "%q" $ref }}
    }
{{ end }}
