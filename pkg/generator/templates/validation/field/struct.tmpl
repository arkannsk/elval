{{ define "struct_validate" }}
    // Вложенная структура {{ .Field.Name }}
    if err := v.{{ .Field.Name }}.Validate(); err != nil {
    return &validator.ValidationError{
    Field: "{{ .Field.Name }}",
    Rule:  "nested",
    Message: "поле {{ .Field.Name }}: " + err.Error(),
    }
    }
{{ end }}